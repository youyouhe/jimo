FROM node:20-alpine

RUN npm install -g pnpm@9

WORKDIR /app

# Copy workspace config
COPY release/lowcode/pnpm-workspace.yaml release/lowcode/package.json release/lowcode/pnpm-lock.yaml* release/lowcode/.npmrc ./
COPY release/lowcode/tsconfig.base.json ./

# Copy package.json files for dependency layer caching
COPY release/lowcode/packages/shared/package.json packages/shared/tsconfig.json ./packages/shared/
COPY release/lowcode/packages/shared/src ./packages/shared/src
COPY release/lowcode/apps/web/package.json apps/web/tsconfig.json ./apps/web/

# Install all dependencies
RUN pnpm install --frozen-lockfile

# Copy source (apps/web/src and .umirc.ts are mounted as volumes in dev)
COPY release/lowcode/apps/web/src ./apps/web/src
COPY release/lowcode/apps/web/.umirc.ts ./apps/web/

WORKDIR /app/apps/web

ENV HOST=0.0.0.0
ENV PORT=8000

CMD ["pnpm", "run", "dev"]

EXPOSE 8000
