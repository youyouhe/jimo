# PostgreSQL connection (required)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://lowcode:lowcode123@localhost:5432/lowcode_db

# Redis connection (required for JWT blacklist and cache)
REDIS_URL=redis://localhost:6379

# JWT secrets — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_another_32_byte_hex_secret

# Token expiry (seconds)
JWT_EXPIRES_IN=7200
JWT_REFRESH_EXPIRES_IN=604800

# Server
APP_PORT=8888

# MinIO object storage
# Endpoint host without protocol (e.g., localhost or play.min.io)
MINIO_ENDPOINT=localhost
# Alternative: set port explicitly, defaults to 9000 (or 443 when MINIO_USE_SSL=true)
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lowcode-dev
MINIO_USE_SSL=false

# BPM service
BPM_SERVICE_URL=http://localhost:8090
