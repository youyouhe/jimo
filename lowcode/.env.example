# =============================================================
# Low-Code Platform — Environment Variables
# Usage: cp .env.example .env
# =============================================================

# ---------- PostgreSQL (NestJS main DB) ----------
POSTGRES_DB=lowcode_db
POSTGRES_USER=lowcode
POSTGRES_PASSWORD=lowcode123

# Full URL (auto-constructed in docker-compose, set manually for local dev)
DATABASE_URL=postgresql://lowcode:lowcode123@localhost:5432/lowcode_db

# ---------- MySQL (bpm-service, Flowable) ----------
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=gin_vue_admin

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- JWT Secrets ----------
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret

# Token expiry (seconds)
JWT_EXPIRES_IN=7200
JWT_REFRESH_EXPIRES_IN=604800

# ---------- Server ----------
APP_PORT=8888
NODE_ENV=development

# ---------- BPM Service ----------
BPM_SERVICE_URL=http://bpm-service:8090
