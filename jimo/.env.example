# =============================================================
# Low-Code Platform — Environment Variables
# Usage: cp .env.example .env
# =============================================================

# ---------- PostgreSQL (NestJS main DB) ----------
POSTGRES_DB=lowcode_db
POSTGRES_USER=lowcode
POSTGRES_PASSWORD=lowcode123

# Full URL (auto-constructed in docker-compose, set manually for local dev)
DATABASE_URL=postgresql://lowcode:lowcode123@localhost:5432/lowcode_db

# ---------- MySQL (bpm-service, Flowable) ----------
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=gin_vue_admin

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- JWT Secrets ----------
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret

# Token expiry (seconds)
JWT_EXPIRES_IN=7200
JWT_REFRESH_EXPIRES_IN=604800

# ---------- Server ----------
APP_PORT=8888
NODE_ENV=development

# ---------- BPM Service ----------
# Local dev (NestJS on host, BPM in docker): http://localhost:8090
# All-in-docker (NestJS in the compose network): http://bpm-service:8090
BPM_SERVICE_URL=http://localhost:8090

# Shared secret for the BPM → NestJS approval-outcome webhook.
# MUST equal the BPM service's NESTJS_CALLBACK_SECRET (its default is
# change-me-in-prod). Without it, approval statuses never advance past PENDING
# (the callback is rejected with 401). Change both sides together in prod.
BPM_CALLBACK_SECRET=change-me-in-prod

# BPM user id that NestJS uses to call BPM's admin/sync APIs (org mirror,
# approval start). A synced user; the seed gives EMP008 admin perms in BPM.
BPM_SYNC_USER_ID=EMP008
