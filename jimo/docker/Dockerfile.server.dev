FROM node:20-alpine

RUN npm install -g pnpm@9

WORKDIR /app

# Copy workspace config
COPY release/lowcode/pnpm-workspace.yaml release/lowcode/package.json release/lowcode/pnpm-lock.yaml* release/lowcode/.npmrc ./
COPY release/lowcode/tsconfig.base.json ./

# Copy package.json files for all workspaces (for dependency install layer caching)
COPY release/lowcode/packages/shared/package.json packages/shared/tsconfig.json ./packages/shared/
COPY release/lowcode/apps/server/package.json apps/server/tsconfig.json apps/server/nest-cli.json ./apps/server/

# Install all dependencies
RUN pnpm install --frozen-lockfile

# Copy source code (packages/shared and apps/server/src are mounted as volumes in dev)
COPY release/lowcode/packages/shared/src ./packages/shared/src
COPY release/lowcode/apps/server/src ./apps/server/src
COPY release/lowcode/apps/server/drizzle.config.ts ./apps/server/
COPY release/lowcode/apps/server/migrations ./apps/server/migrations

WORKDIR /app/apps/server

# Run migrations then start with hot reload
CMD sh -c "npx drizzle-kit migrate && pnpm run db:seed && pnpm run dev"

EXPOSE 8888
