# Dependencies
node_modules/

# Build / generated artifacts
**/.umi/
**/.umi-production/
**/dist/
**/*.tsbuildinfo

# ── Autocode-generated source files ──────────────────────────────────────────
# Files generated at runtime by the autocode engine (sys_auto_code_histories).
# These are runtime artifacts — do NOT commit them.
#
# New structure (lc_ prefix convention enforced):
#   lc_students  →  schema:  db/schema/lc-students.ts
#                   module:  modules/lc/<pkg-slug>/lc-student/
#                   page:    pages/lc/lc-students/
#                   service: services/lc/lc-student.ts
#
# ── Frontend ─────────────────────────────────────────────────────────────────
jimo/apps/web/src/pages/lc/
jimo/apps/web/src/services/lc/
#
# ── Backend schema ────────────────────────────────────────────────────────────
jimo/apps/server/src/db/schema/lc-*.ts
#
# ── Backend modules — one rule covers all packages ────────────────────────────
jimo/apps/server/src/modules/lc/
#
# ── Generated module barrel ───────────────────────────────────────────────────
jimo/apps/server/src/generated.module.ts
#
# ── Generated routes barrel ───────────────────────────────────────────────────
jimo/apps/web/src/generated-routes.ts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Playwright (e2e) — output & caches; the config file (playwright.config.ts) stays tracked
test-results/
playwright-report/
blob-report/
**/playwright/.cache/

# Local AI / tooling config (machine-specific, not shared)
.mcp.json
.playwright-mcp/

# Turborepo cache & test coverage
.turbo/
coverage/

# Java / BPM (Spring Boot + Maven build output)
target/
*.class
